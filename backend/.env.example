# Coinbase Advanced Trade API (CDP-Key erstellen unter https://portal.cdp.coinbase.com/access/api)
# Der Key-Name aus der cdp_api_key.json, z.B. organizations/xxx/apiKeys/yyy
COINBASE_API_KEY=

# Der Private Key aus der cdp_api_key.json.
# Zeilenumbrueche als \n schreiben, alles in eine Zeile:
# COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMHcCAQEE...\n-----END EC PRIVATE KEY-----\n
COINBASE_API_SECRET=

# Optional: Discord-Webhook fuer Kauf-Benachrichtigungen (leer lassen = deaktiviert)
DISCORD_WEBHOOK_URL=

# Server-Einstellungen (Defaults reichen normalerweise)
HOST=0.0.0.0
PORT=8000
