# Coinbase Advanced Trade API (create a CDP key at https://portal.cdp.coinbase.com/access/api)
# The key name from your cdp_api_key.json, e.g. organizations/xxx/apiKeys/yyy
COINBASE_API_KEY=

# The private key from your cdp_api_key.json.
# Write line breaks as \n so everything fits on one line:
# COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMHcCAQEE...\n-----END EC PRIVATE KEY-----\n
COINBASE_API_SECRET=

# Optional: Discord webhook for buy notifications (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Server settings (defaults are usually fine)
HOST=0.0.0.0
PORT=8000
